# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ============================================================================
# GIFLIF — original media archive
# Raw, unprocessed photos and videos live here for editorial selection.
# Web-ready optimised versions belong in `public/images/` and `public/video/`.
# Originals are excluded from Git to keep the repo small and clones fast.
# ============================================================================

# Internal scratch / preview folders — never committed
**/_thumbs/
**/_scratch/

/Speaker Images/
/Speaker Images/**
/Indiestaan Website images/
/Indiestaan Website images/**
/Original Media/
/Original Media/**
/Source Footage/
/Source Footage/**
/Clips/
/Clips/**
/GIFLIF logo/
/GIFLIF logo/**
/Indiestaan Logo/
/Indiestaan Logo/**

# Photoshop / vector source files — keep masters local only
*.psd
*.PSD
*.ai
*.AI
*.sketch

# Camera RAW formats — never web-ready
*.NEF
*.RAW
*.ARW
*.CR2

# Source video — too big for Git. Process into web-ready frames in
# /public/sequence/ (small WebP series for scrolly hero) instead.
*.MOV
*.mov
*.MP4
*.mp4
*.AVI
*.avi
*.MKV
*.mkv


